# Docker-exposed ports. Change these if the defaults collide with another local stack.
USAGE_OBSERVER_POSTGRES_PORT=20000
USAGE_OBSERVER_OTLP_GRPC_PORT=20001
USAGE_OBSERVER_OTLP_HTTP_PORT=20002
USAGE_OBSERVER_COLLECTOR_PROMETHEUS_PORT=20003
USAGE_OBSERVER_OTEL_HEALTHCHECK_PORT=20004
USAGE_OBSERVER_PROMETHEUS_PORT=20005
USAGE_OBSERVER_LOKI_PORT=20006
USAGE_OBSERVER_TEMPO_PORT=20007
USAGE_OBSERVER_INGEST_API_PORT=20008
USAGE_OBSERVER_GRAFANA_PORT=20009

# Claude runtime export targets.
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:20002
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp

# Health-check endpoints used by the wrapper.
USAGE_OBSERVER_OTEL_HEALTHCHECK_URL=http://127.0.0.1:20004/
USAGE_OBSERVER_API_URL=http://127.0.0.1:20008
USAGE_OBSERVER_API_HEALTH_URL=http://127.0.0.1:20008/v1/health

# Ingest API auth and worker development defaults.
INGEST_API_AUTH_TOKEN=local-observer-token
USAGE_OBSERVER_AUTH_TOKEN=local-observer-token
DATABASE_URL=postgres://usage_observer:usage_observer@127.0.0.1:20000/usage_observer
LOKI_BASE_URL=http://127.0.0.1:20006
LOOKBACK_RANGE=7d
ROLLUP_INTERVAL_MS=300000
