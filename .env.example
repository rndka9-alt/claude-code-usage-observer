# Docker-exposed ports. Change these if the defaults collide with another local stack.
USAGE_OBSERVER_POSTGRES_PORT=5432
USAGE_OBSERVER_OTLP_GRPC_PORT=4317
USAGE_OBSERVER_OTLP_HTTP_PORT=4318
USAGE_OBSERVER_COLLECTOR_PROMETHEUS_PORT=9464
USAGE_OBSERVER_OTEL_HEALTHCHECK_PORT=13133
USAGE_OBSERVER_PROMETHEUS_PORT=9090
USAGE_OBSERVER_LOKI_PORT=3100
USAGE_OBSERVER_TEMPO_PORT=3200
USAGE_OBSERVER_INGEST_API_PORT=8080
USAGE_OBSERVER_GRAFANA_PORT=3000

# Claude runtime export targets.
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp

# Health-check endpoints used by the wrapper.
USAGE_OBSERVER_OTEL_HEALTHCHECK_URL=http://127.0.0.1:13133/
USAGE_OBSERVER_API_URL=http://127.0.0.1:8080
USAGE_OBSERVER_API_HEALTH_URL=http://127.0.0.1:8080/v1/health

# Ingest API auth and worker development defaults.
INGEST_API_AUTH_TOKEN=local-observer-token
USAGE_OBSERVER_AUTH_TOKEN=local-observer-token
DATABASE_URL=postgres://usage_observer:usage_observer@127.0.0.1:5432/usage_observer
LOKI_BASE_URL=http://127.0.0.1:3100
LOOKBACK_RANGE=7d
ROLLUP_INTERVAL_MS=300000

# Wrapper default command. Override this to point at another Claude launcher.
OBSERVED_CLAUDE_COMMAND=claude
